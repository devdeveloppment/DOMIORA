# --- Core ---
SECRET_KEY=change-this-to-a-long-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL) ---
# Leave unset to use local SQLite automatically.
DATABASE_URL=postgres://domiora:domiora@localhost:5432/domiora

# --- Email / SMTP ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=DOMIORA <contact@domiora.com>
ADMIN_NOTIFICATION_EMAIL=contact@domiora.com

# --- AI Assistant (optional) ---
# Laissez vide pour utiliser l'assistant par défaut (recherche par mots-clés).
# Sinon, ajoutez votre clé Google Gemini pour une IA conversationnelle complète.
GEMINI_API_KEY=

# --- Security (production) ---
CSRF_TRUSTED_ORIGINS=https://your-domain.com
SECURE_SSL_REDIRECT=True
